# FinOps Assistant — environment template.
# Copy to `.env` and fill in real values. NEVER commit the real `.env` (it is gitignored).
# In production these come from an OpenShift Secret, not a file.

# ── Bedrock / AWS (backend — the LLM agent) ───────────────────────────────────
# Required for the agent's LLM review. Train + predict works WITHOUT these.
AWS_REGION=eu-central-1
BEDROCK_MODEL_ID=eu.amazon.nova-2-lite-v1:0
AWS_ACCESS_KEY_ID=<your-access-key-id>
AWS_SECRET_ACCESS_KEY=<your-secret-access-key>
# AWS_SESSION_TOKEN=                     # only for temporary credentials

# ── API authentication (shared service token) ────────────────────────────────
# The frontend sends `Authorization: Bearer <token>`; the backend validates it.
# Same value on both sides. If UNSET, backend auth is DISABLED (local dev only).
# Generate one:  python -c "import secrets; print(secrets.token_urlsafe(32))"
FINOPS_API_TOKEN=change-me-in-real-use

# ── Frontend → backend wiring ─────────────────────────────────────────────────
# Where the Streamlit client finds the API. Compose sets this to http://backend:8000;
# for local (non-container) dev the default http://127.0.0.1:8000 is used if unset.
# FINOPS_API_URL=http://127.0.0.1:8000

# ── Databricks (backend — the data source) ────────────────────────────────────
# The pipeline pulls the learning + to-predict rows straight from this table. Auth is an
# Azure AD Service Principal (client-credentials flow). All five are required.
DATABRICKS_HOST=adb-xxxxxxxxxxxxxxxx.xx.azuredatabricks.net
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/xxxxxxxxxxxxxxxx
DATABRICKS_CATALOG_TABLE=adb_finops_dv_en1.gold.gld_rectifier_resources_mappedto_data_enrichment
AZURE_SPN_TENANT_ID=<azure-ad-tenant-id>
AZURE_SPN_CLIENT_ID=<service-principal-app-id>
AZURE_SPN_CLIENT_SECRET=<service-principal-secret>

# ── AWS accounts DB (backend — AWS enrichment) ────────────────────────────────
# Postgres holding aws_raw_data.aws_accounts (account_id + tags: owner, global.dcs,
# description, name). Read directly and joined onto Databricks rows on SubAccountId →
# account_id. Best-effort: if unreachable, AWS rows keep empty enrichment.
# Either a full DSN…
# DATABASE_URL=postgresql://user:pass@host:5432/dbname
# …or the individual parts:
DB_HOST=<postgres-host>
DB_PORT=5432
DB_NAME=<database-name>
DB_USER=<db-user>
DB_PASSWORD=<db-password>
# DB_SSLMODE=require                       # set if the DB requires TLS
# AWS_ACCOUNTS_TABLE=aws_raw_data.aws_accounts
#
# To use the exposed HTTP API instead of the DB (e.g. from the corporate network), set
# EITHER of these — when set, the API is used and the DB_* vars above are ignored:
# AWS_ACCOUNTS_SOURCE=api                  # uses the default corporate URL below
# AWS_ACCOUNTS_API_URL=https://finops-backend.ago-fr-dev-int.merlot.eu-central-1.aws.openpaas.axa-cloud.com/data/aws-accounts
# AWS_ACCOUNTS_API_TOKEN=                  # optional bearer token if the API needs it

# ── Learning store (backend — the feedback loop) ──────────────────────────────
# Local CSV where approved/corrected decisions are appended, then merged onto the
# Databricks learning rows on the next run. Defaults to ./learning_store.csv.
# LEARNING_STORE_PATH=learning_store.csv
