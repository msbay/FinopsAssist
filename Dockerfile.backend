# FinOps Assistant — BACKEND (FastAPI: engine + LLM agent)
# Multi-stage: build deps into a venv, then copy only the venv + source into a slim runtime.

# ── Stage 1: builder — install dependencies into an isolated venv ──────────────
FROM python:3.11-slim AS builder
WORKDIR /app
RUN python -m venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
# pyproject only → this layer caches until deps change (code changes don't re-install)
COPY pyproject.toml ./
RUN pip install --no-cache-dir ".[backend]"

# ── Stage 2: runtime — slim image with just the venv + app code ───────────────
FROM python:3.11-slim
WORKDIR /app
COPY --from=builder /opt/venv /opt/venv
ENV PATH="/opt/venv/bin:$PATH"
COPY src/backend ./src/backend

# OpenShift-friendly: an arbitrary non-root UID (group 0) must write the learning store.
RUN chown -R 1001:0 /app && chmod -R g+rwX /app
USER 1001

EXPOSE 8000
HEALTHCHECK --interval=10s --timeout=3s --retries=12 \
  CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8000/health')" || exit 1

# Bind 0.0.0.0; the learning store path resolves against WORKDIR /app.
CMD ["uvicorn", "api:app", "--app-dir", "src/backend", "--host", "0.0.0.0", "--port", "8000"]
